pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/santxrx/ProyectoJenkins.git', branch: 'main'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Verify WAR') {
            steps {
                sh 'ls -la target'
            }
        }

        stage('SonarQube Analysis') {
    steps {
        withSonarQubeEnv('SonarQube') {
            sh 'mvn sonar:sonar'
        }
    }
}

stage('Quality Gate') {
    steps {
        timeout(time: 10, unit: 'MINUTES') {
            waitForQualityGate abortPipeline: true
        }
    }
}

        stage('Deploy to Tomcat') {
            steps {
                sh '''
                cp target/*.war /opt/homebrew/opt/tomcat/libexec/webapps/
                '''
            }
        }
    }

    post {
        success {
            echo 'Deploy OK  (WAR copiado a Tomcat)'
        }

        failure {
            echo 'Pipeline falló'
        }
    }
}